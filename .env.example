APP_NAME=ecoFlow
APP_VERSION=0.1.0
DEBUG=false
HOST=127.0.0.1
PORT=18080
DATABASE_URL=postgresql+asyncpg://ecoflow_user:CHANGE_PASSWORD@localhost/ecoflow_db
ECOSOFT_BASE_URL=https://www.ecosoftapi.net
ECOSOFT_TOKEN_AUTH=
ECOSOFT_TOKEN_USUARIO=
ECOSOFT_DEFAULT_SUCURSAL=1
ECOSOFT_DEFAULT_GASTO_ARTICULO_REF=GASTO_GENERICO
OPENROUTER_API_KEY=
OPENAI_API_KEY=
MEDIA_BASE_PATH=/var/ecoflow/media
LOG_PATH=/var/log/ecoflow/app.jsonl
JOB_MAX_ATTEMPTS=3
JOB_STALE_MINUTES=5
AUTO_APPROVE_MAX_AMOUNT=0.0
