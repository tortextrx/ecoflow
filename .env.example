# ecoFlow Configuration (Template)
APP_NAME=ecoFlow
APP_VERSION=1.0.1
DEBUG=false
HOST=127.0.0.1
PORT=18080

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/db

# ecoSoftWEB API (NC=1, 2, 6, x)
ECOSOFT_BASE_URL=https://www.ecosoftapi.net
ECOSOFT_TOKEN_AUTH=your_auth_token_here
ECOSOFT_TOKEN_USUARIO=your_user_token_here
ECOSOFT_DEFAULT_SUCURSAL=1
ECOSOFT_DEFAULT_GASTO_ARTICULO_REF=GASTO_GENERICO

# AI Intelligence
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENAI_API_KEY=sk-xxx # Optional, used if OpenRouter fails or for specific vision tasks

# Storage & Logging
MEDIA_BASE_PATH=/var/ecoflow/media
LOG_PATH=/var/log/ecoflow/app.jsonl

# Flows
AUTO_APPROVE_MAX_AMOUNT=0.0
JOB_MAX_ATTEMPTS=3
JOB_STALE_MINUTES=5
